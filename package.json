{
  "name": "soha-web",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "check:release-workflow": "node scripts/check-release-workflow.mjs",
    "browser:baseline": "node scripts/browser-regression-baseline.mjs",
    "release:verify-dist": "node scripts/verify-release-artifact.mjs",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write README.md package.json package-lock.json tsconfig.json vite.config.ts tailwind.config.ts postcss.config.js index.html eslint.config.js .prettierrc.json .github/workflows/*.yml src/App.tsx src/main.tsx src/components/app-error-boundary.tsx src/components/global-api-error-handler.tsx src/services/api-client.ts src/services/api-client.test.ts src/services/api-error.ts src/styles/globals.css",
    "format:check": "prettier --check README.md package.json package-lock.json tsconfig.json vite.config.ts tailwind.config.ts postcss.config.js index.html eslint.config.js .prettierrc.json .github/workflows/*.yml src/App.tsx src/main.tsx src/components/app-error-boundary.tsx src/components/global-api-error-handler.tsx src/services/api-client.ts src/services/api-client.test.ts src/services/api-error.ts src/styles/globals.css",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ant-design/charts": "^2.6.5",
    "@ant-design/icons": "^6.0.1",
    "@ant-design/x": "^2.1.3",
    "@antv/g6": "^5.0.49",
    "@monaco-editor/react": "^4.7.0",
    "@novnc/novnc": "^1.7.0",
    "@opensoha/contracts": "file:../soha-contracts",
    "@tailwindcss/vite": "^4.1.5",
    "@tanstack/react-query": "^5.75.7",
    "@visactor/react-vchart": "^2.0.22",
    "@visactor/vchart": "^2.0.22",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.2",
    "antd": "6.4.3",
    "axios": "^1.9.0",
    "dagre": "^0.8.5",
    "dayjs": "^1.11.13",
    "monaco-editor": "^0.55.1",
    "monaco-yaml": "^5.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "react-window": "^2.2.7",
    "zod": "^3.24.4",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/dagre": "^0.7.54",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.1.5",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.2.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "geojson-flatten": {
      "minimist": "1.2.8"
    },
    "monaco-editor": {
      "dompurify": "3.4.11"
    }
  }
}
